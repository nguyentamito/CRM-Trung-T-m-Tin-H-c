{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Thông tin người dùng hệ thống",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Thông tin khách hàng",
      "type": "object",
      "properties": {
        "consultationDate": { "type": "number" },
        "fbLink": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "subject": { "type": "string" },
        "status": { "type": "string", "enum": ["Đã đóng tiền", "Đã cọc", "Đã chốt", "Phân vân", "Hẹn lại", "Khác"] },
        "notes": { "type": "string" },
        "closedAmount": { "type": "string" },
        "source": { "type": "string" },
        "ownerId": { "type": "string" },
        "ownerName": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["name", "status", "ownerId", "ownerName", "createdAt", "updatedAt"]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "Lịch sử trao đổi với khách hàng",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "content": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["đã liên hệ", "chưa phản hồi", "quan tâm", "từ chối"] },
        "staffId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["customerId", "content", "staffId"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Lịch hẹn với khách hàng",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "time": { "type": "number" },
        "content": { "type": "string" },
        "staffId": { "type": "string" },
        "status": { "type": "string", "enum": ["đã diễn ra", "hoãn", "hủy", "chưa diễn ra"] },
        "createdAt": { "type": "number" }
      },
      "required": ["customerId", "customerName", "customerPhone", "time", "staffId"]
    },
    "Subject": {
      "title": "Subject",
      "description": "Danh sách môn học",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "createdAt"]
    },
    "Teacher": {
      "title": "Teacher",
      "description": "Thông tin giáo viên",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "subjects": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "phone", "createdAt"]
    },
    "TeachingAssistant": {
      "title": "TeachingAssistant",
      "description": "Thông tin trợ giảng",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "phone", "createdAt"]
    },
    "Class": {
      "title": "Class",
      "description": "Thông tin lớp học",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "studentIds": { "type": "array", "items": { "type": "string" } },
        "studentNames": { "type": "array", "items": { "type": "string" } },
        "subject": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "taId": { "type": "string" },
        "taName": { "type": "string" },
        "schedule": { "type": "string" },
        "startDate": { "type": "number" },
        "status": { "type": "string", "enum": ["đang học", "kết thúc", "tạm dừng"] },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["name", "studentIds", "studentNames", "subject", "teacherId", "teacherName", "status", "createdAt", "updatedAt"]
    },
    "TeachingSession": {
      "title": "TeachingSession",
      "description": "Thông tin buổi học cụ thể",
      "type": "object",
      "properties": {
        "classId": { "type": "string" },
        "className": { "type": "string" },
        "subject": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "taId": { "type": "string" },
        "taName": { "type": "string" },
        "date": { "type": "number" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "status": { "type": "string", "enum": ["đang học", "kết thúc", "tạm dừng"] },
        "createdAt": { "type": "number" }
      },
      "required": ["classId", "className", "subject", "teacherId", "teacherName", "date", "startTime", "endTime", "status", "createdAt"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Thông tin điểm danh học viên",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "classId": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "status": { "type": "string", "enum": ["có mặt", "vắng mặt", "muộn", "phép"] },
        "note": { "type": "string" },
        "takenById": { "type": "string" },
        "takenByName": { "type": "string" },
        "updatedAt": { "type": "number" }
      },
      "required": ["sessionId", "classId", "studentId", "studentName", "status", "takenById", "takenByName", "updatedAt"]
    },
    "Receipt": {
      "title": "Receipt",
      "description": "Phiếu thu học phí khách hàng",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "receiptNumber": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "subject": { "type": "string" },
        "amount": { "type": "number" },
        "totalAmount": { "type": "number" },
        "remainingAmount": { "type": "number" },
        "type": { "type": "string", "enum": ["cọc", "đóng tất", "đóng 100%"] },
        "paymentMethod": { "type": "string", "enum": ["tiền mặt", "chuyển khoản", "khác"] },
        "note": { "type": "string" },
        "staffId": { "type": "string" },
        "staffName": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["customerId", "customerName", "customerPhone", "subject", "amount", "totalAmount", "remainingAmount", "type", "paymentMethod", "staffId", "staffName", "createdAt", "receiptNumber"]
    },
    "CenterInfo": {
      "title": "Center Info",
      "description": "Thông tin trung tâm hiển thị trên biên lai",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "website": { "type": "string" },
        "updatedAt": { "type": "number" }
      },
      "required": ["name", "address", "website", "updatedAt"]
    },
    "PaymentVoucher": {
      "title": "Payment Voucher",
      "description": "Phiếu chi tiền của trung tâm",
      "type": "object",
      "properties": {
        "voucherNumber": { "type": "string" },
        "category": { "type": "string", "enum": ["lương nhân viên", "lương giáo viên", "lương trợ giảng", "tiền nhà", "tiền điện", "tiền nước", "văn phòng phẩm", "marketing", "khác"] },
        "recipientName": { "type": "string" },
        "recipientId": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["tiền mặt", "chuyển khoản", "khác"] },
        "staffId": { "type": "string" },
        "staffName": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["voucherNumber", "category", "recipientName", "amount", "description", "paymentMethod", "staffId", "staffName", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Profiles of system users"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customer records"
    },
    "/interactions/{interactionId}": {
      "schema": "Interaction",
      "description": "Interaction history records"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointment records"
    },
    "/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "Subject records"
    },
    "/teachers/{teacherId}": {
      "schema": "Teacher",
      "description": "Teacher records"
    },
    "/teaching_assistants/{taId}": {
      "schema": "TeachingAssistant",
      "description": "Teaching assistant records"
    },
    "/classes/{classId}": {
      "schema": "Class",
      "description": "Class records"
    },
    "/teaching_sessions/{sessionId}": {
      "schema": "TeachingSession",
      "description": "Specific teaching session records"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance records"
    },
    "/receipts/{receiptId}": {
      "schema": "Receipt",
      "description": "Receipt records"
    },
    "/center_info/{id}": {
      "schema": "CenterInfo",
      "description": "Center information for receipts"
    },
    "/payment_vouchers/{voucherId}": {
      "schema": "PaymentVoucher",
      "description": "Payment voucher records"
    }
  }
}
