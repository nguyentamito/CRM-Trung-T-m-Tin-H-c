rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (required)
    //   - role: string (required, enum: ['admin', 'staff', 'teacher'])
    //   - isApproved: boolean (required)
    //
    // Collection: customers
    // Document ID: auto-generated
    // Fields:
    //   - consultationDate: number
    //   - fbLink: string
    //   - name: string (required)
    //   - phone: string
    //   - subject: string
    //   - status: string (required, enum: ['Đã đóng tiền', 'Đã cọc', 'Đã chốt', 'Phân vân', 'Hẹn lại', 'Khác'])
    //   - notes: string
    //   - closedAmount: string
    //   - source: string
    //   - ownerId: string (required)
    //   - ownerName: string (required)
    //   - createdAt: number (required)
    //   - updatedAt: number (required)
    //
    // Collection: interactions
    // Document ID: auto-generated
    // Fields:
    //   - customerId: string (required)
    //   - content: string (required)
    //   - notes: string
    //   - status: string (required, enum: ['đã liên hệ', 'chưa phản hồi', 'quan tâm', 'từ chối'])
    //   - staffId: string (required)
    //   - createdAt: number (required)
    //
    // Collection: appointments
    // Document ID: auto-generated
    // Fields:
    //   - customerId: string (required)
    //   - customerName: string (required)
    //   - customerPhone: string (required)
    //   - time: number (required)
    //   - content: string (required)
    //   - staffId: string (required)
    //   - status: string (required, enum: ['đã diễn ra', 'hoãn', 'hủy', 'chưa diễn ra', 'khách không đến'])
    //   - createdAt: number (required)
    //
    // Collection: subjects
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - createdAt: number (required)
    //
    // Collection: teachers
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - phone: string (required)
    //   - email: string
    //   - subjects: list (required)
    //   - createdAt: number (required)
    //
    // Collection: teaching_assistants
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - phone: string (required)
    //   - email: string
    //   - createdAt: number (required)
    //
    // Collection: classes
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - studentIds: list (required)
    //   - studentNames: list (required)
    //   - subject: string (required)
    //   - teacherId: string (required)
    //   - teacherName: string (required)
    //   - taId: string
    //   - taName: string
    //   - schedule: string
    //   - startDate: number
    //   - status: string (required, enum: ['đang học', 'kết thúc', 'tạm dừng'])
    //   - createdAt: number (required)
    //   - updatedAt: number (required)
    //
    // Collection: teaching_sessions
    // Document ID: auto-generated
    // Fields:
    //   - classId: string (required)
    //   - className: string (required)
    //   - subject: string (required)
    //   - teacherId: string (required)
    //   - teacherName: string (required)
    //   - taId: string
    //   - taName: string
    //   - date: number (required)
    //   - startTime: string (required)
    //   - endTime: string (required)
    //   - status: string (required, enum: ['đang học', 'kết thúc', 'tạm dừng'])
    //   - createdAt: number (required)
    //
    // Collection: center_info
    // Document ID: auto-generated (usually 'default')
    // Fields:
    //   - name: string (required)
    //   - address: string (required)
    //   - website: string (required)
    //   - updatedAt: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          request.auth.token.email == "nguyentamito@gmail.com" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isStaff() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff';
    }

    function isTeacher() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function isTA() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ta';
    }

    function isCollaborator() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'collaborator';
    }

    function isApproved() {
      return isAuthenticated() && 
        (
          request.auth.token.email == "nguyentamito@gmail.com" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true)
        );
    }

    // Domain Validators
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'isApproved']) &&
             data.uid is string && data.email is string && data.displayName is string &&
             data.role in ['admin', 'staff', 'teacher', 'ta', 'collaborator'] &&
             data.isApproved is bool;
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['name', 'status', 'ownerId', 'ownerName', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.status in ['Đã đóng tiền', 'Đã cọc', 'Đã chốt', 'Phân vân', 'Hẹn lại', 'Khác'] &&
             data.ownerId is string &&
             data.ownerName is string && data.ownerName.size() > 0 && data.ownerName.size() < 100 &&
             data.createdAt is number && data.updatedAt is number &&
             (!('consultationDate' in data) || data.consultationDate is number) &&
             (!('fbLink' in data) || data.fbLink is string) &&
             (!('phone' in data) || data.phone is string) &&
             (!('subject' in data) || data.subject is string) &&
             (!('notes' in data) || data.notes is string) &&
             (!('closedAmount' in data) || data.closedAmount is string) &&
             (!('source' in data) || data.source is string);
    }

    function isValidInteraction(data) {
      return data.keys().hasAll(['customerId', 'content', 'status', 'staffId', 'createdAt']) &&
             data.customerId is string && data.content is string && data.content.size() < 5000 &&
             data.status in ['đã liên hệ', 'chưa phản hồi', 'quan tâm', 'từ chối'] &&
             data.staffId is string && data.createdAt is number;
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['customerId', 'customerName', 'customerPhone', 'time', 'content', 'staffId', 'status', 'createdAt']) &&
             data.customerId is string && data.customerName is string && data.customerPhone is string &&
             data.time is number && data.content is string && data.content.size() < 1000 &&
             data.staffId is string && data.status in ['đã diễn ra', 'hoãn', 'hủy', 'chưa diễn ra', 'khách không đến'] &&
             data.createdAt is number;
    }

    function isValidSubject(data) {
      return data.keys().hasAll(['name', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.createdAt is number;
    }

    function isValidTeacher(data) {
      return data.keys().hasAll(['name', 'phone', 'email', 'subjects', 'createdAt']) &&
             data.name is string && data.name.size() > 0 &&
             data.phone is string && data.email is string &&
             data.subjects is list && data.createdAt is number;
    }

    function isValidTA(data) {
      return data.keys().hasAll(['name', 'phone', 'email', 'createdAt']) &&
             data.name is string && data.name.size() > 0 &&
             data.phone is string && data.email is string &&
             data.createdAt is number;
    }

    function isValidClass(data) {
      return data.keys().hasAll(['name', 'studentIds', 'studentNames', 'subject', 'teacherId', 'teacherName', 'status', 'createdAt', 'updatedAt']) &&
             data.name is string && data.studentIds is list && data.studentNames is list &&
             data.subject is string && data.teacherId is string && data.teacherName is string &&
             data.status in ['đang học', 'kết thúc', 'tạm dừng'] &&
             data.createdAt is number && data.updatedAt is number &&
             (!('taId' in data) || data.taId is string) &&
             (!('taName' in data) || data.taName is string) &&
             (!('schedule' in data) || data.schedule is string) &&
             (!('startDate' in data) || data.startDate is number) &&
             (!('roomId' in data) || data.roomId is string) &&
             (!('roomName' in data) || data.roomName is string) &&
             (!('roomLink' in data) || data.roomLink is string);
    }

    function isValidTeachingSession(data) {
      return data.keys().hasAll(['classId', 'className', 'subject', 'teacherId', 'teacherName', 'date', 'startTime', 'endTime', 'status', 'createdAt']) &&
             data.classId is string && data.className is string && data.subject is string &&
             data.teacherId is string && data.teacherName is string &&
             data.date is number && data.startTime is string && data.endTime is string &&
             data.status in ['đang học', 'kết thúc', 'tạm dừng'] &&
             data.createdAt is number &&
             (!('taId' in data) || data.taId is string) &&
             (!('taName' in data) || data.taName is string) &&
             (!('roomId' in data) || data.roomId is string) &&
             (!('roomName' in data) || data.roomName is string) &&
             (!('roomLink' in data) || data.roomLink is string);
    }

    function isValidAttendance(data) {
      return data.keys().hasAll(['sessionId', 'classId', 'studentId', 'studentName', 'status', 'takenById', 'takenByName', 'updatedAt']) &&
             data.sessionId is string && data.classId is string && data.studentId is string &&
             data.studentName is string && data.status in ['có mặt', 'vắng mặt', 'muộn', 'phép'] &&
             data.takenById is string && data.takenByName is string &&
             data.updatedAt is number &&
             (!('note' in data) || data.note is string);
    }

    function isValidReceipt(data) {
      return data.keys().hasAll(['customerId', 'customerName', 'customerPhone', 'subject', 'amount', 'totalAmount', 'remainingAmount', 'type', 'paymentMethod', 'staffId', 'staffName', 'date', 'status', 'createdAt', 'updatedAt', 'receiptNumber']) &&
             data.customerId is string && data.customerName is string && data.customerPhone is string &&
             data.receiptNumber is string &&
             data.subject is string && data.amount is number && data.totalAmount is number &&
             data.remainingAmount is number &&
             data.type in ['cọc', 'đóng tất', 'đóng 100%', 'thu khác'] &&
             data.paymentMethod in ['tiền mặt', 'chuyển khoản', 'khác'] &&
             data.staffId is string && data.staffName is string && 
             data.date is number &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.createdAt is number && data.updatedAt is number &&
             (!('note' in data) || data.note is string) &&
             (!('attachmentUrl' in data) || data.attachmentUrl is string);
    }

    function isValidCenterInfo(data) {
      return data.keys().hasAll(['name', 'address', 'website', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 &&
             data.address is string && data.address.size() > 0 &&
             data.website is string && data.updatedAt is number;
    }

    function isValidPaymentVoucher(data) {
      return data.keys().hasAll(['voucherNumber', 'category', 'recipientName', 'amount', 'description', 'paymentMethod', 'staffId', 'staffName', 'date', 'status', 'createdAt', 'updatedAt']) &&
             data.voucherNumber is string &&
             data.category in ['lương nhân viên', 'lương giáo viên', 'lương trợ giảng', 'tiền nhà', 'tiền điện', 'tiền nước', 'văn phòng phẩm', 'marketing', 'khác'] &&
             data.recipientName is string && data.recipientName.size() > 0 &&
             data.amount is number && data.amount > 0 &&
             data.description is string &&
             data.paymentMethod in ['tiền mặt', 'chuyển khoản', 'khác'] &&
             data.staffId is string && data.staffName is string &&
             data.date is number &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.createdAt is number && data.updatedAt is number &&
             (!('recipientId' in data) || data.recipientId is string) &&
             (!('attachmentUrl' in data) || data.attachmentUrl is string);
    }

    function isValidRoom(data) {
      return data.keys().hasAll(['name', 'type', 'location', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 &&
             data.type in ['Phòng máy tính', 'Phòng lý thuyết', 'Phòng Online', 'Gia Sư', 'Doanh nghiệp'] &&
             data.location is string &&
             data.createdAt is number && data.updatedAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'staff' || isAdmin()) &&
                      (request.resource.data.isApproved == false || isAdmin());
      allow update: if (isOwner(uid) && 
                        request.resource.data.role == resource.data.role && 
                        request.resource.data.isApproved == resource.data.isApproved && 
                        isValidUser(request.resource.data)) || isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isAuthenticated() && (isAdmin() || (isApproved() && resource.data.ownerId == request.auth.uid));
      allow create: if isApproved() && isValidCustomer(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isApproved() && isValidCustomer(request.resource.data) && 
                      (isAdmin() || (resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == resource.data.ownerId));
      allow delete: if isAdmin();
    }

    match /interactions/{interactionId} {
      allow read: if isApproved();
      allow create: if isApproved() && isValidInteraction(request.resource.data) && request.resource.data.staffId == request.auth.uid;
      allow update: if isApproved() && isValidInteraction(request.resource.data) && 
                      (isAdmin() || resource.data.staffId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && (isAdmin() || isApproved());
      allow create: if isApproved() && isValidAppointment(request.resource.data) && request.resource.data.staffId == request.auth.uid;
      allow update: if isApproved() && isValidAppointment(request.resource.data) && 
                      (isAdmin() || resource.data.staffId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /subjects/{subjectId} {
      allow read: if isAdmin() || isApproved();
      allow create, update: if isAdmin() && isValidSubject(request.resource.data);
      allow delete: if isAdmin();
    }

    match /teachers/{teacherId} {
      allow read: if isAdmin() || isApproved();
      allow create, update: if isAdmin() && isValidTeacher(request.resource.data);
      allow delete: if isAdmin();
    }

    match /teaching_assistants/{taId} {
      allow read: if isAdmin() || isApproved();
      allow create, update: if isAdmin() && isValidTA(request.resource.data);
      allow delete: if isAdmin();
    }

    match /classes/{classId} {
      allow read: if isAdmin() || isApproved();
      allow create, update: if isAdmin() && isValidClass(request.resource.data);
      allow delete: if isAdmin();
    }

    match /teaching_sessions/{sessionId} {
      allow read: if isAdmin() || isApproved();
      allow create, update: if isAdmin() && isValidTeachingSession(request.resource.data);
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isAdmin() || isApproved();
      allow create, update: if (isAdmin() || (isApproved() && (isStaff() || isTeacher()))) && isValidAttendance(request.resource.data);
      allow delete: if isAdmin();
    }

    match /receipts/{receiptId} {
      allow read: if isAdmin() || isApproved();
      allow create: if (isAdmin() || (isApproved() && isStaff())) && isValidReceipt(request.resource.data);
      allow update: if isAdmin() && isValidReceipt(request.resource.data);
      allow delete: if isAdmin();
    }

    match /center_info/{id} {
      allow read: if isAdmin() || isApproved();
      allow write: if isAdmin() && isValidCenterInfo(request.resource.data);
    }

    match /payment_vouchers/{voucherId} {
      allow read: if isAdmin() || isApproved();
      allow create: if (isAdmin() || (isApproved() && isStaff())) && isValidPaymentVoucher(request.resource.data);
      allow update: if isAdmin() && isValidPaymentVoucher(request.resource.data);
      allow delete: if isAdmin();
    }

    match /rooms/{roomId} {
      allow read: if isAdmin() || isApproved();
      allow create, update: if isAdmin() && isValidRoom(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
